# Frontend environment template.
#   cp .env.example .env   (inside the frontend/ folder)
#
# Vite only exposes vars prefixed with VITE_ to the browser.

# Base URL of the backend API.
# - Local dev: leave as-is (defaults to http://localhost:3000 if unset).
# - Production: set to your deployed backend URL, e.g. https://ayc-api.onrender.com
VITE_API_URL=http://localhost:3000
