# ---------------------------------------------------------------------------
# .env.example  —  template for the backend's environment variables.
#
# HOW TO USE:
#   cp .env.example backend/.env
# then fill in the two API keys below. `backend/.env` is git-ignored so your
# real keys never get committed.
# ---------------------------------------------------------------------------

# --- Database -------------------------------------------------------------
# Connection string for the pgvector Postgres container from docker-compose.yml.
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
# These credentials match docker-compose.yml — change both if you change them.
DATABASE_URL=postgres://ayc:ayc_password@localhost:5432/ask_your_codebase

# --- Gemini (ANSWER GENERATION) -------------------------------------------
# Used by @google/genai to generate the natural-language, cited answer.
# Get a FREE key from Google AI Studio:  https://aistudio.google.com/apikey
# IMPORTANT: this is the developer API key (starts with "AIza..."). It is NOT
# the consumer "Gemini Advanced / Pro" app subscription — that does not grant
# API access. The AI Studio free tier is plenty for this project.
GEMINI_API_KEY=your_google_ai_studio_key_here

# Which Gemini model to use for generation. gemini-2.0-flash is fast + cheap.
# Confirm the current model IDs in Google AI Studio if this one is unavailable.
GEMINI_MODEL=gemini-2.0-flash

# --- Voyage AI (EMBEDDINGS) -----------------------------------------------
# Used to turn code chunks + your question into vectors for similarity search.
# voyage-code-3 is tuned specifically for source code. Free key from:
# https://www.voyageai.com/  (dashboard -> API Keys)
VOYAGE_API_KEY=your_voyage_api_key_here

# Embedding model + its output dimension. voyage-code-3 returns 1024 dims.
# If you change the model, update VOYAGE_DIM AND the vector(1024) size in
# backend/src/db/schema.sql to match, then recreate the table.
VOYAGE_MODEL=voyage-code-3
VOYAGE_DIM=1024

# --- Server ---------------------------------------------------------------
PORT=3000
