# ---------------------------------------------------------------------------
# .env.example  —  template for the backend's environment variables.
#
# HOW TO USE:
#   cp .env.example backend/.env
# then fill in the two API keys below. `backend/.env` is git-ignored so your
# real keys never get committed.
# ---------------------------------------------------------------------------

# --- Database -------------------------------------------------------------
# Connection string for the pgvector Postgres container from docker-compose.yml.
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
# These credentials match docker-compose.yml — change both if you change them.
DATABASE_URL=postgres://ayc:ayc_password@localhost:5432/ask_your_codebase

# --- Gemini (POWERS BOTH GENERATION *AND* EMBEDDINGS) ---------------------
# One key drives everything: generating the answer AND turning code/questions
# into vectors. Get a FREE key from Google AI Studio:
#   https://aistudio.google.com/apikey
# IMPORTANT: this is the developer API key (starts with "AIza..."). It is NOT
# the consumer "Gemini Advanced / Pro" app subscription — that does not grant
# API access. The AI Studio free tier is plenty for this project (no payment).
GEMINI_API_KEY=your_google_ai_studio_key_here

# Which Gemini model generates the answer. gemini-2.5-flash is free + capable.
# (If your key reports "free tier limit 0" for a model, try -lite or another
#  model — run a quick :generateContent test to see what your key allows.)
GEMINI_MODEL=gemini-2.5-flash

# --- Embeddings (also Gemini) ---------------------------------------------
# gemini-embedding-001 is the current GA embedding model. It can output up to
# 3072 dims; we request 768 (set below) so it matches the DB column. Generous
# free tier (unlike Voyage's unpaid tier, which throttles to 3 requests/min).
# If you change EMBEDDING_DIM, also update the vector(768) size in
# backend/src/db/schema.sql, then recreate the code_chunks table.
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIM=768

# --- Server ---------------------------------------------------------------
PORT=3000
